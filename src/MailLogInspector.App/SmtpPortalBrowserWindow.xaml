<Window x:Class="MailLogInspector.App.SmtpPortalBrowserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Mail Log Inspector - SMTP.com diagnose"
        Width="1180"
        Height="800"
        MinWidth="900"
        MinHeight="640"
        WindowStartupLocation="CenterScreen"
        Background="#F3F5F8">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>
    <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#CBD7E4" BorderThickness="0,0,0,1" Padding="14,10">
      <TextBlock Name="PortalStatusTextBlock"
                 Text="SMTP.com-portaal voorbereiden..."
                 Foreground="#405570"
                 FontSize="13" />
    </Border>
    <wv2:WebView2 Name="PortalWebView" Grid.Row="1" />
  </Grid>
</Window>
