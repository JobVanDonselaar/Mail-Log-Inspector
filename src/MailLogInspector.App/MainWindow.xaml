          <Button Name="PopupCalendarPreviousButton" Grid.Row="0" Grid.Column="0" Style="{StaticResource PopupCalendarNavigationButtonStyle}" Content="&#xE76B;" ToolTip="2 maanden terug" Click="PopupCalendarPreviousButton_Click" />
          <TextBlock Name="LeftMonthTitleTextBlock" Grid.Row="0" Grid.Column="1" TextAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="12" />
          <TextBlock Name="RightMonthTitleTextBlock" Grid.Row="0" Grid.Column="2" TextAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="12" />
          <Button Name="PopupCalendarNextButton" Grid.Row="0" Grid.Column="3" Style="{StaticResource PopupCalendarNavigationButtonStyle}" Content="&#xE76C;" ToolTip="2 maanden vooruit" Click="PopupCalendarNextButton_Click" />
          <Border Name="PopupCalendarMonthDivider" Grid.Row="0" Grid.RowSpan="3" Grid.Column="2"
                  Width="1" HorizontalAlignment="Left" Margin="-1,0,0,0"
                  Background="{StaticResource PanelStrokeBrush}" Panel.ZIndex="2" />

          <UniformGrid Grid.Row="1" Grid.Column="1" Columns="7" Margin="0,8,0,4">
            <TextBlock Text="M" TextAlignment="Center" FontWeight="SemiBold" FontSize="11" />
            <TextBlock Text="D" TextAlignment="Center" FontWeight="SemiBold" FontSize="11" />
            <TextBlock Text="W" TextAlignment="Center" FontWeight="SemiBold" FontSize="11" />
            <TextBlock Text="D" TextAlignment="Center" FontWeight="SemiBold" FontSize="11" />
            <TextBlock Text="V" TextAlignment="Center" FontWeight="SemiBold" FontSize="11" />
            <TextBlock Text="Z" TextAlignment="Center" FontWeight="SemiBold" FontSize="11" />
            <TextBlock Text="Z" TextAlignment="Center" FontWeight="SemiBold" FontSize="11" />
          </UniformGrid>
          <UniformGrid Grid.Row="1" Grid.Column="2" Columns="7" Margin="0,8,0,4">
            <TextBlock Text="M" TextAlignment="Center" FontWeight="SemiBold" FontSize="11" />
            <TextBlock Text="D" TextAlignment="Center" FontWeight="SemiBold" FontSize="11" />
            <TextBlock Text="W" TextAlignment="Center" FontWeight="SemiBold" FontSize="11" />
            <TextBlock Text="D" TextAlignment="Center" FontWeight="SemiBold" FontSize="11" />
            <TextBlock Text="V" TextAlignment="Center" FontWeight="SemiBold" FontSize="11" />
            <TextBlock Text="Z" TextAlignment="Center" FontWeight="SemiBold" FontSize="11" />
            <TextBlock Text="Z" TextAlignment="Center" FontWeight="SemiBold" FontSize="11" />
          </UniformGrid>

          <ItemsControl Name="LeftMonthDaysItemsControl" Grid.Row="2" Grid.Column="1">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <UniformGrid Columns="7" Rows="6" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Button Style="{StaticResource PopupCalendarDayButtonStyle}" Content="{Binding DisplayText}" Tag="{Binding Date}" IsEnabled="{Binding IsSelectable}" Click="PopupCalendarDayButton_Click" />
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <ItemsControl Name="RightMonthDaysItemsControl" Grid.Row="2" Grid.Column="2">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <UniformGrid Columns="7" Rows="6" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Button Style="{StaticResource PopupCalendarDayButtonStyle}" Content="{Binding DisplayText}" Tag="{Binding Date}" IsEnabled="{Binding IsSelectable}" Click="PopupCalendarDayButton_Click" />
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </Grid>
      </Border>
    </Popup>

    <Border Panel.ZIndex="5"
            VerticalAlignment="Top"
            Height="48"
            Margin="775,0,18,0"
            Padding="14,8,14,0"
            Background="#F3F5F8"
            BorderBrush="{StaticResource PanelStrokeBrush}"
            BorderThickness="0,0,0,1"
            SnapsToDevicePixels="True">
      <Grid VerticalAlignment="Center">
        <Grid Name="SearchTopStatusPanel">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="6" />
          </Grid.RowDefinitions>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource AccentBrush}" Margin="0,0,10,0" VerticalAlignment="Center" />
              <TextBlock Name="SearchRunStateTextBlock" Text="Kies filters en klik Zoeken." VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock Name="SearchRunDetailTextBlock" Grid.Column="1" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" Text="" TextTrimming="CharacterEllipsis" Visibility="Collapsed" />
            <Button Name="SearchCancelButton" Grid.Column="2" Style="{StaticResource SecondaryButtonStyle}" Padding="10,3" Margin="14,0,0,0" Visibility="Collapsed" Click="SearchCancelButton_Click">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource DangerBrush}" Margin="0,0,6,0" />
                <TextBlock Text="Stop" Foreground="{StaticResource DangerBrush}" FontWeight="SemiBold" />
              </StackPanel>
            </Button>
          </Grid>
          <ProgressBar Name="SearchRunProgressBar" Grid.Row="1" Height="6" Minimum="0" Maximum="100" Value="0" Visibility="Collapsed" />
        </Grid>

        <Grid Name="AnalysisTopStatusPanel" Visibility="Collapsed">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="6" />
          </Grid.RowDefinitions>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource AccentBrush}" Margin="0,0,10,0" VerticalAlignment="Center" />
              <TextBlock Name="AnalysisRunStateTextBlock" Text="Kies eerst een expliciete periode en start daarna de analyse." VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock Name="AnalysisRunDurationTextBlock" Grid.Column="1" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" Text="Nog niet uitgevoerd." />
          </Grid>
          <TextBlock Name="AnalysisDataCoverageTextBlock" Grid.Row="1" Foreground="{StaticResource MutedTextBrush}" Text="" TextTrimming="CharacterEllipsis" Visibility="Collapsed" />
          <ProgressBar Name="AnalysisRunProgressBar" Grid.Row="2" Height="6" Minimum="0" Maximum="100" Value="0" Visibility="Collapsed" />
        </Grid>

        <Grid Name="ManageTopStatusPanel" Visibility="Collapsed">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="170" />
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <TextBlock Name="StatusTextBlock" Text="Gereed." FontWeight="SemiBold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
          <ProgressBar Name="ImportProgressBar" Grid.Column="1" Height="8" Minimum="0" Maximum="100" Value="0" VerticalAlignment="Center" Margin="16,0,16,0" />
          <TextBlock Name="ImportProgressTextBlock" Grid.Column="2" Text="Nog geen actieve import." Foreground="{StaticResource MutedTextBrush}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
          <Button Name="SyncCancelButton"
                  Grid.Column="3"
                  Style="{StaticResource SecondaryButtonStyle}"
                  Padding="10,3"
                  Margin="14,0,0,0"
                  Visibility="Collapsed"
                  Click="SyncCancelButton_Click">
            <TextBlock Text="Stop" Foreground="{StaticResource DangerBrush}" FontWeight="SemiBold" />
          </Button>
        </Grid>

        <Grid Name="HelpTopStatusPanel" Visibility="Collapsed">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource AccentBrush}" Margin="0,0,10,0" VerticalAlignment="Center" />
            <TextBlock Text="Korte uitleg over import, zoeken, analyse en maandarchieven." VerticalAlignment="Center" />
          </StackPanel>
        </Grid>
      </Grid>
    </Border>
    <Border Name="StartupOverlay" Panel.ZIndex="20" Background="#F3F6FA" Opacity="0.98" Visibility="Visible">
      <Border Width="440" Padding="26" Background="White" BorderBrush="{StaticResource PanelStrokeBrush}" BorderThickness="1" CornerRadius="8" HorizontalAlignment="Center" VerticalAlignment="Center">
        <StackPanel>
          <TextBlock Text="Mail Log Inspector" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" HorizontalAlignment="Center" />
          <TextBlock Name="StartupStatusTextBlock" Text="Applicatie wordt voorbereid..." Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Center" Margin="0,8,0,14" />
          <ProgressBar Name="StartupProgressBar" Height="7" IsIndeterminate="True" />
          <TextBlock Text="De database en analysegegevens worden gecontroleerd." Style="{StaticResource MutedTextStyle}" HorizontalAlignment="Center" Margin="0,12,0,0" />
        </StackPanel>
      </Border>
    </Border>
  </Grid>
</Window>
