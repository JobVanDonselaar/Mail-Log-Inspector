<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="MailLogInspector.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MailLogInspector.App"
        Title="Mail Log Inspector"
        Width="1560"
        Height="930"
        MinWidth="1280"
        MinHeight="820"
        Background="#F3F5F8"
        FontFamily="Segoe UI"
        Icon="Assets/MailLogInspector.ico"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        WindowStartupLocation="CenterScreen">
  <Window.Resources>
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F3F5F8" />
    <SolidColorBrush x:Key="PanelFillBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="PanelSubtleFillBrush" Color="#F8FAFC" />
    <SolidColorBrush x:Key="PanelStrokeBrush" Color="#D8E0EA" />
    <SolidColorBrush x:Key="StrongStrokeBrush" Color="#B9C5D2" />
    <SolidColorBrush x:Key="TextBrush" Color="#1F2937" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="#637386" />
    <SolidColorBrush x:Key="AccentBrush" Color="#1F5D8C" />
    <SolidColorBrush x:Key="AccentDarkBrush" Color="#17486E" />
    <SolidColorBrush x:Key="SuccessBrush" Color="#2F855A" />
    <SolidColorBrush x:Key="WarningBrush" Color="#C77912" />
    <SolidColorBrush x:Key="DangerBrush" Color="#C83B2B" />

    <Style TargetType="{x:Type TextBlock}">
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
      <Setter Property="FontSize" Value="13" />
    </Style>

    <Style x:Key="IconTextStyle" TargetType="{x:Type TextBlock}">
      <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
      <Setter Property="FontSize" Value="16" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
    </Style>

    <Style x:Key="LabelTextStyle" TargetType="{x:Type TextBlock}">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
      <Setter Property="Margin" Value="0,0,0,6" />
    </Style>

    <Style x:Key="SectionTitleStyle" TargetType="{x:Type TextBlock}">
      <Setter Property="FontSize" Value="15" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
    </Style>

    <Style x:Key="MutedTextStyle" TargetType="{x:Type TextBlock}">
      <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
      <Setter Property="FontSize" Value="12" />
    </Style>

    <Style x:Key="PanelBorderStyle" TargetType="{x:Type Border}">
      <Setter Property="Background" Value="{StaticResource PanelFillBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource PanelStrokeBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Padding" Value="16" />
      <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style x:Key="MetricCardStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource PanelBorderStyle}">
      <Setter Property="Padding" Value="12,8" />
      <Setter Property="Margin" Value="0,0,12,0" />
      <Setter Property="MinHeight" Value="56" />
    </Style>

    <Style x:Key="PrimaryButtonStyle" TargetType="{x:Type Button}">
      <Setter Property="MinHeight" Value="38" />
      <Setter Property="Padding" Value="16,8" />
      <Setter Property="Margin" Value="0,0,8,0" />
      <Setter Property="Background" Value="{StaticResource AccentBrush}" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type Button}">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="4"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="{StaticResource AccentDarkBrush}" />
          <Setter Property="BorderBrush" Value="{StaticResource AccentDarkBrush}" />
        </Trigger>
        <Trigger Property="IsEnabled" Value="False">
          <Setter Property="Opacity" Value="0.5" />
        </Trigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="SecondaryButtonStyle" TargetType="{x:Type Button}">
      <Setter Property="MinHeight" Value="38" />
      <Setter Property="Padding" Value="16,8" />
      <Setter Property="Margin" Value="0,0,8,0" />
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource StrongStrokeBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type Button}">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="4"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="#F4F7FA" />
        </Trigger>
        <Trigger Property="IsEnabled" Value="False">
          <Setter Property="Opacity" Value="0.45" />
        </Trigger>
      </Style.Triggers>
    </Style>

    <Style TargetType="{x:Type TextBox}">
      <Setter Property="Height" Value="34" />
      <Setter Property="Padding" Value="9,5" />
      <Setter Property="BorderBrush" Value="{StaticResource PanelStrokeBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Background" Value="White" />
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
    </Style>

    <Style TargetType="{x:Type ComboBox}">
      <Setter Property="Height" Value="34" />
      <Setter Property="Padding" Value="8,4" />
      <Setter Property="BorderBrush" Value="{StaticResource PanelStrokeBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Background" Value="White" />
    </Style>

    <Style TargetType="{x:Type DatePicker}">
      <Setter Property="Height" Value="34" />
      <Setter Property="BorderBrush" Value="{StaticResource PanelStrokeBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="SelectedDateFormat" Value="Short" />
    </Style>

    <Style x:Key="PopupCalendarNavigationButtonStyle" TargetType="{x:Type Button}">
      <Setter Property="Width" Value="28" />
      <Setter Property="Height" Value="28" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
      <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type Button}">
            <Border Background="{TemplateBinding Background}" CornerRadius="14">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="#EAF2F8" />
        </Trigger>
        <Trigger Property="IsEnabled" Value="False">
          <Setter Property="Opacity" Value="0.28" />
          <Setter Property="Cursor" Value="Arrow" />
        </Trigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="PopupCalendarDayButtonStyle" TargetType="{x:Type Button}">
      <Setter Property="Width" Value="24" />
      <Setter Property="Height" Value="22" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="1" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type Button}">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="3">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="#EAF2F8" />
        </Trigger>
        <DataTrigger Binding="{Binding IsSelected}" Value="True">
          <Setter Property="Background" Value="{StaticResource AccentBrush}" />
          <Setter Property="Foreground" Value="White" />
          <Setter Property="FontWeight" Value="SemiBold" />
        </DataTrigger>
        <Trigger Property="IsEnabled" Value="False">
          <Setter Property="Opacity" Value="0.32" />
          <Setter Property="Cursor" Value="Arrow" />
        </Trigger>
      </Style.Triggers>
    </Style>
    <Style TargetType="{x:Type DataGrid}">
      <Setter Property="Background" Value="White" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="GridLinesVisibility" Value="None" />
      <Setter Property="HorizontalGridLinesBrush" Value="Transparent" />
      <Setter Property="RowHeaderWidth" Value="0" />
      <Setter Property="HeadersVisibility" Value="Column" />
      <Setter Property="CanUserResizeRows" Value="False" />
      <Setter Property="SelectionMode" Value="Single" />
      <Setter Property="SelectionUnit" Value="FullRow" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="RowHeight" Value="22" />
      <Setter Property="ColumnHeaderHeight" Value="24" />
      <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
      <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
      <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
    </Style>

    <Style TargetType="{x:Type DataGridColumnHeader}">
      <Setter Property="Background" Value="#F8FAFC" />
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="BorderBrush" Value="#EDF1F5" />
      <Setter Property="BorderThickness" Value="0,0,0,1" />
      <Setter Property="Padding" Value="4,0" />
    </Style>

    <Style TargetType="{x:Type DataGridCell}">
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="4,0" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="FocusVisualStyle" Value="{x:Null}" />
    </Style>

    <Style TargetType="{x:Type DataGridRow}">
      <Setter Property="Height" Value="22" />
      <Setter Property="MinHeight" Value="0" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style TargetType="{x:Type TabControl}">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style TargetType="{x:Type TabItem}">
      <Setter Property="MinWidth" Value="190" />
      <Setter Property="Height" Value="48" />
      <Setter Property="Margin" Value="0,0,4,0" />
      <Setter Property="Padding" Value="18,0" />
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type TabItem}">
            <Grid>
              <Border x:Name="TabBorder"
                      Margin="0,4,0,0"
                      Background="#EEF1F5"
                      BorderBrush="{StaticResource StrongStrokeBrush}"
                      BorderThickness="1,1,1,0"
                      CornerRadius="7,7,0,0">
                <ContentPresenter ContentSource="Header"
                                  HorizontalAlignment="Left"
                                  VerticalAlignment="Center"
                                  Margin="{TemplateBinding Padding}" />
              </Border>
            </Grid>
            <ControlTemplate.Triggers>
              <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource PanelFillBrush}" />
                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{StaticResource PanelStrokeBrush}" />
                <Setter Property="FontWeight" Value="SemiBold" />
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="TabBorder" Property="Background" Value="#F8FAFC" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <TabControl Name="MainTabControl" Grid.Row="0" Margin="18,0,18,18" SelectionChanged="MainTabControl_SelectionChanged">
      <TabItem>
        <TabItem.Header>
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="&#xE721;" Style="{StaticResource IconTextStyle}" Margin="0,0,10,0" />
            <TextBlock Text="Zoeken" FontSize="14" VerticalAlignment="Center" />
          </StackPanel>
        </TabItem.Header>
        <Grid Background="{StaticResource PanelFillBrush}">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>

          <Border Grid.Row="0" Style="{StaticResource PanelBorderStyle}" Margin="0,0,0,12">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <Grid Grid.Column="0">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="120" />
                  <ColumnDefinition Width="120" />
                  <ColumnDefinition Width="212" />
                  <ColumnDefinition Width="212" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                  <TextBlock Text="Van" Style="{StaticResource LabelTextStyle}" />
                  <DatePicker Name="SearchFromDatePicker" SelectedDateChanged="DatePicker_SelectedDateChanged" PreviewMouseDown="DatePicker_PreviewMouseDown" PreviewMouseUp="DatePicker_PreviewMouseUp" PreviewKeyDown="DatePicker_PreviewKeyDown" CalendarOpened="DatePicker_CalendarOpened" />
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="0,0,12,0">
                  <TextBlock Text="Tot en met" Style="{StaticResource LabelTextStyle}" />
                  <DatePicker Name="SearchThroughDatePicker" SelectedDateChanged="DatePicker_SelectedDateChanged" PreviewMouseDown="DatePicker_PreviewMouseDown" PreviewMouseUp="DatePicker_PreviewMouseUp" PreviewKeyDown="DatePicker_PreviewKeyDown" CalendarOpened="DatePicker_CalendarOpened" />
                </StackPanel>
                <StackPanel Grid.Column="2" Margin="0,0,12,0">
                  <TextBlock Text="Afzender" Style="{StaticResource LabelTextStyle}" />
                  <TextBox Name="SenderTextBox" TextChanged="SearchDashboardInputs_Changed" />
                </StackPanel>
                <StackPanel Grid.Column="3">
                  <TextBlock Text="Ontvanger" Style="{StaticResource LabelTextStyle}" />
                  <TextBox Name="RecipientTextBox" TextChanged="SearchDashboardInputs_Changed" />
                </StackPanel>
              </Grid>
              <Grid Grid.Column="2">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="144" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                  <TextBlock Text="Resultaten" Style="{StaticResource LabelTextStyle}" />
                  <ComboBox Name="SearchLimitComboBox" SelectedIndex="2">
                    <ComboBoxItem Content="100" Tag="100" />
                    <ComboBoxItem Content="250" Tag="250" />
                    <ComboBoxItem Content="500" Tag="500" />
                    <ComboBoxItem Content="1000" Tag="1000" />
                    <ComboBoxItem Content="5000" Tag="5000" />
                    <ComboBoxItem Content="alles" Tag="-1" />
                  </ComboBox>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                  <CheckBox Name="SenderDomainDashboardCheckBox"
                            Content="Domeinanalyse tonen"
                            Margin="0,0,16,0"
                            VerticalAlignment="Center"
                            IsEnabled="False"
                            Checked="SenderDomainDashboardOption_Changed"
                            Unchecked="SenderDomainDashboardOption_Changed" />
                  <Button Name="SearchButton" Style="{StaticResource PrimaryButtonStyle}" Click="SearchButton_Click">
                    <StackPanel Orientation="Horizontal">
                      <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0" />
                      <TextBlock Text="Zoeken" Foreground="White" FontWeight="SemiBold" />
                    </StackPanel>
                  </Button>
                  <Button Name="LoadMoreSearchResultsButton" Content="Meer laden" Style="{StaticResource SecondaryButtonStyle}" IsEnabled="False" Click="LoadMoreSearchResultsButton_Click" />
                  <Button Name="ExportSearchResultsButton" Style="{StaticResource SecondaryButtonStyle}" Click="ExportSearchResultsButton_Click">
                    <StackPanel Orientation="Horizontal">
                      <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0" />
                      <TextBlock Text="Excel exporteren" />
                    </StackPanel>
                  </Button>
                </StackPanel>
              </Grid>
            </Grid>
          </Border>

          <UniformGrid Grid.Row="1" Columns="5" Margin="0,0,0,8">
            <Border Style="{StaticResource MetricCardStyle}">
              <Grid>
                <StackPanel Margin="58,0,0,0" VerticalAlignment="Center">
                  <TextBlock Name="SearchTotalCountTextBlock" FontSize="26" FontWeight="SemiBold" Margin="0,1,0,0" />
                </StackPanel>
                <Border Width="42" Height="42" CornerRadius="21" Background="#EEF5FC" HorizontalAlignment="Left" ToolTip="Verzonden">
                  <TextBlock Text="&#xE724;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource AccentBrush}" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
              </Grid>
            </Border>
            <Border Style="{StaticResource MetricCardStyle}">
              <Grid>
                <StackPanel Margin="58,0,0,0" VerticalAlignment="Center">
                  <TextBlock Name="SearchDeliveredCountTextBlock" FontSize="26" FontWeight="SemiBold" Margin="0,1,0,0" />
                </StackPanel>
                <Border Width="42" Height="42" CornerRadius="21" Background="#EAF5EF" HorizontalAlignment="Left" ToolTip="Afgeleverd">
                  <TextBlock Text="&#xE715;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource SuccessBrush}" FontSize="21" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
              </Grid>
            </Border>
            <Border Style="{StaticResource MetricCardStyle}">
              <Grid>
                <StackPanel Margin="58,0,0,0" VerticalAlignment="Center">
                  <TextBlock Name="SearchDeliveredPercentTextBlock" FontSize="26" FontWeight="SemiBold" Margin="0,1,0,0" />
                </StackPanel>
                <Border Width="42" Height="42" CornerRadius="21" Background="#EAF5EF" HorizontalAlignment="Left" ToolTip="% Afgeleverd">
                  <TextBlock Text="%" Foreground="{StaticResource SuccessBrush}" FontSize="20" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
              </Grid>
            </Border>
            <Border Name="SearchUnderwayMetricCard" Style="{StaticResource MetricCardStyle}">
              <Grid>
                <StackPanel Margin="58,0,0,0" VerticalAlignment="Center">
                  <TextBlock Name="SearchUnderwayCountTextBlock" FontSize="26" FontWeight="SemiBold" Margin="0,1,0,0" />
                </StackPanel>
                <Border Width="42" Height="42" CornerRadius="21" Background="#FFF4DE" HorizontalAlignment="Left" ToolTip="Onderweg">
                  <TextBlock Text="&#xE823;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource WarningBrush}" FontSize="21" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
              </Grid>
            </Border>
            <Border Style="{StaticResource MetricCardStyle}" Margin="0">
              <Grid>
                <StackPanel Margin="58,0,0,0" VerticalAlignment="Center">
                  <TextBlock Name="SearchBounceCountTextBlock" FontSize="26" FontWeight="SemiBold" Margin="0,1,0,0" />
                </StackPanel>
                <Border Width="42" Height="42" CornerRadius="21" Background="#FDECE9" HorizontalAlignment="Left" ToolTip="Bounce">
                  <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource DangerBrush}" FontSize="21" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
              </Grid>
            </Border>
          </UniformGrid>

          <Grid Name="SearchResultsDashboardLayoutGrid" Grid.Row="2">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Name="SearchResultsPanel" Grid.Column="0" Grid.ColumnSpan="5" Style="{StaticResource PanelBorderStyle}" Padding="0">
              <DataGrid Name="SearchResultsGrid" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" FontSize="11" RowHeight="30" ColumnHeaderHeight="30">
                <DataGrid.Columns>
                  <DataGridTextColumn Header="Accepted" Width="132" Binding="{Binding AcceptedDisplay}" />
                  <DataGridTemplateColumn Header="" Width="28">
                    <DataGridTemplateColumn.CellTemplate>
                      <DataTemplate>
                        <Button Content="{Binding ToggleGlyph}"
                                Click="SearchResultToggleButton_Click"
                                Width="18"
                                Height="18"
                                Padding="0"
                                FontSize="10"
                                FontWeight="Bold"
                                Background="Transparent"
                                BorderThickness="0">
                          <Button.Style>
                            <Style TargetType="{x:Type Button}">
                              <Setter Property="Visibility" Value="Visible" />
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding IsGroup}" Value="False">
                                  <Setter Property="Visibility" Value="Hidden" />
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </Button.Style>
                        </Button>
                      </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                  </DataGridTemplateColumn>
                  <DataGridTextColumn Header="Afzender" Width="230" Binding="{Binding SenderDisplay}" />
                  <DataGridTextColumn Header="Ontvanger" Width="215" Binding="{Binding RecipientDisplay}" />
                  <DataGridTextColumn Header="Aantal" Width="62" SortMemberPath="CountValue" Binding="{Binding CountDisplay}" />
                  <DataGridTemplateColumn Width="160" SortMemberPath="StatusDisplay">
                    <DataGridTemplateColumn.Header>
                      <ComboBox Width="108" SelectedIndex="0" Loaded="SearchResultsStatusHeaderComboBox_Loaded" SelectionChanged="SearchResultsStatusHeaderComboBox_SelectionChanged">
                        <ComboBoxItem Content="Alle" Tag="" />
                        <ComboBoxItem Content="Afgeleverd" Tag="afgeleverd" />
                        <ComboBoxItem Content="Onderweg" Tag="onderweg" />
                        <ComboBoxItem Content="Bounce" Tag="bounce" />
                      </ComboBox>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                      <DataTemplate>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                          <Ellipse Width="7" Height="7" Fill="{StaticResource AccentBrush}" Margin="0,0,8,0" />
                          <TextBlock Text="{Binding StatusDisplay}" />
                        </StackPanel>
                      </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                  </DataGridTemplateColumn>
                  <DataGridTextColumn Header="Duur" Width="88" Binding="{Binding DurationDisplay}" />
                </DataGrid.Columns>
              </DataGrid>
            </Border>
            <Grid Name="SenderDomainDashboardPanel" Grid.Column="3" Grid.ColumnSpan="2" Visibility="Collapsed">
              <Grid.RowDefinitions>
                <RowDefinition Height="1.2*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
              </Grid.RowDefinitions>
              <Border Grid.Row="0" Style="{StaticResource PanelBorderStyle}" Margin="0,0,0,8">
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                  </Grid.RowDefinitions>
                  <TextBlock Text="Afleversnelheid laatste 30 dagen" FontWeight="SemiBold" />
                  <UniformGrid Grid.Row="1" Columns="2" Margin="0,10,0,8">
                    <StackPanel>
                      <TextBlock Text="Gem. aflevertijd" Style="{StaticResource LabelTextStyle}" />
                      <TextBlock Name="SenderDomainAverageDurationTextBlock" FontSize="20" FontWeight="SemiBold" />
                    </StackPanel>
                    <StackPanel>
                      <TextBlock Text="95% binnen" Style="{StaticResource LabelTextStyle}" />
                      <TextBlock Name="SenderDomainP95DurationTextBlock" FontSize="20" FontWeight="SemiBold" />
                    </StackPanel>
                  </UniformGrid>
                  <Grid Grid.Row="2" MinHeight="120">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="62" />
                      <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0">
                      <TextBlock Name="SenderDomainTrendMaximumTextBlock" HorizontalAlignment="Right" VerticalAlignment="Top" Foreground="{StaticResource MutedTextBrush}" FontSize="10" Margin="0,0,8,0" />
                      <TextBlock Name="SenderDomainTrendMiddleTextBlock" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" FontSize="10" Margin="0,0,8,0" />
                      <TextBlock Text="0" HorizontalAlignment="Right" VerticalAlignment="Bottom" Foreground="{StaticResource MutedTextBrush}" FontSize="10" Margin="0,0,8,0" />
                    </Grid>
                    <Grid Grid.Column="1">
