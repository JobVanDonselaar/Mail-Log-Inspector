      <TabItem Name="HelpTab">
        <TabItem.Header>
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="&#xE897;" Style="{StaticResource IconTextStyle}" Margin="0,0,10,0" />
            <TextBlock Text="Help" FontSize="14" VerticalAlignment="Center" />
          </StackPanel>
        </TabItem.Header>
        <ScrollViewer Background="{StaticResource PanelSubtleFillBrush}" VerticalScrollBarVisibility="Auto">
          <StackPanel Name="HelpTabContent" MaxWidth="980" Margin="24,20,24,28" HorizontalAlignment="Center">
            <Border Style="{StaticResource PanelBorderStyle}" Padding="24" Margin="0,0,0,14">
              <StackPanel>
                <TextBlock Text="Mail Log Inspector" FontSize="23" FontWeight="SemiBold" Margin="0,0,0,5" />
                <TextBlock Text="Zakelijke naslag voor controle van SMTP-rapporten" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" Margin="0,0,0,8" />
                <TextBlock Text="Mail Log Inspector importeert SMTP-rapporten en maakt afleverresultaten doorzoekbaar. Gebruik de applicatie om volumes, aflevertijden, bounces en oorzaken te controleren zonder de bronbestanden handmatig te bewerken." TextWrapping="Wrap" Foreground="{StaticResource MutedTextBrush}" FontSize="13" />
              </StackPanel>
            </Border>

            <Border Style="{StaticResource PanelBorderStyle}" Padding="22" Margin="0,0,0,14">
              <StackPanel>
                <TextBlock Text="Doel en snel beginnen" Style="{StaticResource SectionTitleStyle}" FontSize="18" Margin="0,0,0,10" />
                <TextBlock Text="&#x2022; Open Zoeken voor afzonderlijke berichten, adressen of domeinen." TextWrapping="Wrap" Margin="0,0,0,6" />
                <TextBlock Text="&#x2022; Open Analyse voor totalen, ranglijsten en SMTP-responsen over een periode." TextWrapping="Wrap" Margin="0,0,0,6" />
                <TextBlock Text="&#x2022; Open Dashboard voor imports, synchronisatie, databasegegevens en archieven." TextWrapping="Wrap" Margin="0,0,0,6" />
                <TextBlock Text="&#x2022; Bij het opstarten maakt de applicatie automatisch de analyse van gisteren. Als gisteren geen gegevens bevat, wordt de laatst beschikbare dag gebruikt." TextWrapping="Wrap" />
              </StackPanel>
            </Border>

            <Border Style="{StaticResource PanelBorderStyle}" Padding="22" Margin="0,0,0,14">
              <StackPanel>
                <TextBlock Text="Zoeken" Style="{StaticResource SectionTitleStyle}" FontSize="18" Margin="0,0,0,10" />
                <TextBlock Text="&#x2022; Van en Tot en met bepalen de volledige zoekperiode. De datumkiezer toont twee aaneengesloten maanden en navigeert per twee maanden." TextWrapping="Wrap" Margin="0,0,0,6" />
                <TextBlock Text="&#x2022; Afzender en Ontvanger accepteren een volledig e-mailadres of een domein. Een afzenderdomein mag met of zonder @ worden ingevoerd." TextWrapping="Wrap" Margin="0,0,0,6" />
                <TextBlock Text="&#x2022; Resultaten bepaalt hoeveel regels eerst worden geladen. Meer laden voegt de volgende regels aan dezelfde zoekactie toe." TextWrapping="Wrap" Margin="0,0,0,6" />
                <TextBlock Text="&#x2022; Berichten met meerdere ontvangers worden gegroepeerd. Klik op het pijltje om de ontvangers uit te klappen; bij één gevonden afzender wordt de groep automatisch geopend." TextWrapping="Wrap" Margin="0,0,0,6" />
                <TextBlock Text="&#x2022; De statusfilter werkt op de volledige zoekset. Afgeleverd is door de ontvangende server geaccepteerd, Onderweg heeft nog geen eindstatus en Bounce toont waar mogelijk direct de korte reden." TextWrapping="Wrap" Margin="0,0,0,6" />
                <TextBlock Text="&#x2022; Aantal is numeriek sorteerbaar. Duur is de tijd tussen accepteren en afleveren; een streepje betekent dat geen bruikbare eindtijd beschikbaar is." TextWrapping="Wrap" />
              </StackPanel>
            </Border>

            <Border Style="{StaticResource PanelBorderStyle}" Padding="22" Margin="0,0,0,14">
              <StackPanel>
                <TextBlock Text="Domeinanalyse en Excel" Style="{StaticResource SectionTitleStyle}" FontSize="18" Margin="0,0,0,10" />
                <TextBlock Text="&#x2022; Domeinanalyse tonen is beschikbaar bij een afzenderdomein zonder ontvangerfilter. Een exact afzenderadres geeft geen domeinanalyse." TextWrapping="Wrap" Margin="0,0,0,6" />
                <TextBlock Text="&#x2022; Afleversnelheid toont maximaal de laatste 30 dagen binnen de gekozen periode, met dagelijks afgeleverd volume, gemiddelde aflevertijd en de 95%-grens." TextWrapping="Wrap" Margin="0,0,0,6" />
                <TextBlock Text="&#x2022; Afleververtraging verdeelt afgeleverde mails over 1-5, 5-15, 15-60 minuten en langer dan één uur. Bounce-oorzaken toont de belangrijkste genormaliseerde oorzaken." TextWrapping="Wrap" Margin="0,0,0,6" />
                <TextBlock Text="&#x2022; Excel exporteren neemt de werkelijk geladen en zichtbare detailregels over. Een actieve domeinanalyse voegt een eerste werkblad Domeinanalyse toe met KPI's, brondata en grafieken." TextWrapping="Wrap" Margin="0,0,0,6" />
                <TextBlock Text="&#x2022; Een statusfilter, bijvoorbeeld alleen bounce, bepaalt welke detailregels naar Excel gaan. De domeinanalyse blijft een overzicht van de volledige gekozen periode." TextWrapping="Wrap" />
              </StackPanel>
            </Border>

            <Border Style="{StaticResource PanelBorderStyle}" Padding="22" Margin="0,0,0,14">
              <StackPanel>
                <TextBlock Text="Analyse" Style="{StaticResource SectionTitleStyle}" FontSize="18" Margin="0,0,0,10" />
                <TextBlock Text="&#x2022; Kies een periode en eventueel een afzender- of ontvangerfilter. Top bepaalt hoeveel domeinen in de ranglijsten worden getoond." TextWrapping="Wrap" Margin="0,0,0,6" />
                <TextBlock Text="&#x2022; De KPI's tonen geaccepteerd, afgeleverd, afleverratio, onderweg en bounced." TextWrapping="Wrap" Margin="0,0,0,6" />
                <TextBlock Text="&#x2022; De ranglijsten tonen de belangrijkste afzender- en ontvangerdomeinen. SMTP-responsen toont Code, Aantal en een korte Omschrijving." TextWrapping="Wrap" Margin="0,0,0,6" />
                <TextBlock Text="&#x2022; Dubbelklik op een domein om dit als filter in Zoeken te openen. De applicatie schakelt daarbij direct naar de tab Zoeken." TextWrapping="Wrap" />
              </StackPanel>
            </Border>

            <Border Style="{StaticResource PanelBorderStyle}" Padding="22" Margin="0,0,0,14">
              <StackPanel>
                <TextBlock Text="Dashboard" Style="{StaticResource SectionTitleStyle}" FontSize="18" Margin="0,0,0,10" />
                <TextBlock Text="&#x2022; De bovenste balk toont databasegrootte, aantal records, imports, beschikbare periode en laatste update." TextWrapping="Wrap" Margin="0,0,0,6" />
                <TextBlock Text="&#x2022; De grafieken tonen afleversnelheid, de laatste import ten opzichte van de vorige week en de belangrijkste oorzaken van de laatste import." TextWrapping="Wrap" Margin="0,0,0,6" />
                <TextBlock Text="&#x2022; Imports is één overzicht van handmatige, SMTP.com- en IMAP-imports. Bron, statusaantallen en eventuele foutinformatie blijven per regel zichtbaar." TextWrapping="Wrap" Margin="0,0,0,6" />
                <TextBlock Text="&#x2022; Gebruik Importeren voor een lokaal CSV- of ZIP-bestand. Nu synchroniseren gebruikt de ingestelde bron en importeert beschikbare dagrapporten." TextWrapping="Wrap" Margin="0,0,0,6" />
                <TextBlock Text="&#x2022; Database verversen leest de beheerinformatie opnieuw. Open map opent de werkmap met database, bronarchief, logs en maandarchieven." TextWrapping="Wrap" />
              </StackPanel>
            </Border>

            <Border Style="{StaticResource PanelBorderStyle}" Padding="22" Margin="0,0,0,14">
              <StackPanel>
                <TextBlock Text="Synchronisatie en beheerdersinstellingen" Style="{StaticResource SectionTitleStyle}" FontSize="18" Margin="0,0,0,10" />
                <TextBlock Text="&#x2022; De bronkeuze is: direct downloaden met IMAP-terugval, alleen direct downloaden of alleen IMAP. De gekozen bron geldt voor automatische en handmatige synchronisatie." TextWrapping="Wrap" Margin="0,0,0,6" />
                <TextBlock Text="&#x2022; De eerste automatische poging start dagelijks om 01:00 lokale tijd. Als het rapport van gisteren nog ontbreekt, volgt iedere 15 minuten een nieuwe poging. Rapportdagen worden uit UTC-tijdstempels bepaald." TextWrapping="Wrap" Margin="0,0,0,6" />
                <TextBlock Text="&#x2022; SMTP.com direct gebruikt een bestaande Ready-rapportregel. Proefdownload controleert download, ZIP en hash zonder te importeren; Diagnose toont dezelfde portaalflow zichtbaar." TextWrapping="Wrap" Margin="0,0,0,6" />
                <TextBlock Text="&#x2022; IMAP ondersteunt Gmail, Microsoft 365 / Outlook.com en een eigen IMAP-server. Verbindingen gebruiken altijd TLS: direct SSL of verplichte STARTTLS." TextWrapping="Wrap" Margin="0,0,0,6" />
                <TextBlock Text="&#x2022; Een actieve synchronisatie kan met Stop worden afgebroken. Downloads, import en databasewrites reageren op die annulering." TextWrapping="Wrap" Margin="0,0,0,6" />
                <TextBlock Text="&#x2022; Wachtwoorden, tokens en het SMTP.com MFA-secret worden versleuteld voor de huidige Windows-gebruiker opgeslagen." TextWrapping="Wrap" Margin="0,0,0,6" />
                <TextBlock Text="&#x2022; Standaardsyntax herkent de vaste NextGen-rapportnaam met delivered, bounced en queue. Aangepaste syntax gebruikt dezelfde zichtbare placeholders voor start- en einddatum." TextWrapping="Wrap" Margin="0,0,0,6" />
                <TextBlock Text="&#x2022; ZIP-bestanden zijn begrensd op 512 MB en CSV-bestanden uitgepakt op 3 GB; ZIPs mogen maximaal 100 bestanden en een compressieverhouding van 200 bevatten." TextWrapping="Wrap" />
              </StackPanel>
            </Border>

            <Border Style="{StaticResource PanelBorderStyle}" Padding="22" Margin="0,0,0,14">
              <StackPanel>
                <TextBlock Text="Database en maandarchieven" Style="{StaticResource SectionTitleStyle}" FontSize="18" Margin="0,0,0,10" />
                <TextBlock Text="&#x2022; De actieve database bevat standaard de laatste 90 dagen. Oudere gegevens worden door de applicatie naar Maandarchieven verplaatst." TextWrapping="Wrap" Margin="0,0,0,6" />
                <TextBlock Text="&#x2022; Open een maandarchief vanuit Dashboard om binnen die maand te zoeken en analyseren. Sluit het archief of kies terug om de actieve database opnieuw te gebruiken." TextWrapping="Wrap" Margin="0,0,0,6" />
                <TextBlock Text="&#x2022; De applicatie maakt een lege database automatisch aan en beheert schemawijzigingen, retentie en rebuilds zelf." TextWrapping="Wrap" Margin="0,0,0,6" />
              </StackPanel>
            </Border>

            <Border Style="{StaticResource PanelBorderStyle}" Padding="22" Margin="0,0,0,14">
              <StackPanel>
                <TextBlock Text="Systeemvak en afsluiten" Style="{StaticResource SectionTitleStyle}" FontSize="18" Margin="0,0,0,10" />
                <TextBlock Text="&#x2022; Met Sluiten naar systeemvak blijft de applicatie actief en kan automatische synchronisatie doorgaan." TextWrapping="Wrap" Margin="0,0,0,6" />
                <TextBlock Text="&#x2022; Dubbelklik op het systeemvakpictogram om het bestaande venster te openen. Een tweede start van de EXE opent eveneens de al actieve instantie." TextWrapping="Wrap" Margin="0,0,0,6" />
                <TextBlock Text="&#x2022; Kies Afsluiten via het systeemvakmenu om de applicatie en automatische synchronisatie volledig te stoppen." TextWrapping="Wrap" />
              </StackPanel>
            </Border>

            <Border Style="{StaticResource PanelBorderStyle}" Padding="22">
              <StackPanel>
                <TextBlock Text="Veelvoorkomende situaties" Style="{StaticResource SectionTitleStyle}" FontSize="18" Margin="0,0,0,10" />
                <TextBlock Text="&#x2022; Geen resultaten: controleer de periode, spelling van adres of domein en het actieve maandarchief." TextWrapping="Wrap" Margin="0,0,0,6" />
                <TextBlock Text="&#x2022; Rapport nog niet beschikbaar: laat automatische synchronisatie actief; de applicatie probeert het ontbrekende dagrapport opnieuw." TextWrapping="Wrap" Margin="0,0,0,6" />
                <TextBlock Text="&#x2022; Synchronisatie- of importfout: open Dashboard en bekijk de bron, status en foutinformatie in Imports. Test daarna zo nodig de ingestelde verbinding via /admin." TextWrapping="Wrap" Margin="0,0,0,6" />
                <TextBlock Text="&#x2022; Domeinanalyse niet beschikbaar: gebruik alleen een afzenderdomein en laat Ontvanger leeg." TextWrapping="Wrap" Margin="0,0,0,6" />
                <TextBlock Text="&#x2022; Technische details staan in Logs\mail-log-inspector.log binnen de actieve werkmap. Oudere logbestanden worden automatisch geroteerd." TextWrapping="Wrap" Margin="0,0,0,12" />
                <Button Name="OpenAdminSettingsButton" Style="{StaticResource SecondaryButtonStyle}" Padding="10,5" Margin="0" HorizontalAlignment="Left" Click="OpenAdminSettingsButton_Click">
                  <TextBlock Text="Beheerdersinstellingen openen" />
                </Button>
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </TabItem>
    </TabControl>

